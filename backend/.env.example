# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Users (hardcoded, change freely) ─────────────────────
USER_USERNAME=utente
USER_PASSWORD=1234
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AlfredJenny#2024!

# ── AI Provider (openai | anthropic | gemini) ─────────────
ACTIVE_PROVIDER=openai

# ── API Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── ElevenLabs TTS (server-side fallback) ────────────────
# If set, used when the Android app doesn't supply its own key.
ELEVENLABS_API_KEY=

# ── Tuya Smart Home ──────────────────────────────────────
# Get credentials from Tuya IoT Platform (iot.tuya.com)
# Leave blank to disable smart home features.
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
# Region base URLs:
#   EU  → https://openapi.tuyaeu.com
#   US  → https://openapi.tuyaus.com
#   CN  → https://openapi.tuyacn.com
#   IN  → https://openapi.tuyain.com
TUYA_BASE_URL=https://openapi.tuyaeu.com
# Optional: filter devices by Tuya user UID (leave blank to show all app devices)
TUYA_USER_UID=

# ── CORS ─────────────────────────────────────────────────
# Comma-separated origins. Use * to allow all (dev only).
CORS_ORIGINS=*
